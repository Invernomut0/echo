# LM Studio connection
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=Qwen2.5-7B-Instruct-Q4_K_M
LM_STUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Database paths
SQLITE_PATH=data/sqlite/echo.db
CHROMA_PATH=data/chroma

# Cognitive parameters
MAX_WORKSPACE_SLOTS=7
CONSOLIDATION_INTERVAL_SECONDS=3600
REFLECTION_TRIGGER_INTERVAL=5
MEMORY_DECAY_INTERVAL_SECONDS=3600

# Performance — self-prediction timeout (seconds).
# On a phone CPU (e.g. OnePlus 7 acting as LM Studio server) the self-prediction
# call can take 40-100 s. Set this to 5 or lower to keep retrieval snappy.
# Default: 10.0  (safe for most desktop CPUs)
ECHO_PREDICT_TIMEOUT_S=10.0

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Telegram bot integration (optional)
# 1) Create a bot with @BotFather and copy its token
# 2) Set TELEGRAM_ENABLED=true
# 3) Optional: restrict access to specific chats with TELEGRAM_ALLOWED_CHAT_IDS
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_POLL_INTERVAL_SECONDS=1.0
TELEGRAM_UPDATE_TIMEOUT_SECONDS=30
TELEGRAM_REQUEST_TIMEOUT_SECONDS=40.0
TELEGRAM_ALLOWED_CHAT_IDS=[]
TELEGRAM_HISTORY_TURNS=6
TELEGRAM_MAX_REPLY_CHARS=3900

# Logging
LOG_LEVEL=INFO

# ── Embeddings ──────────────────────────────────────────────────────────────
# Primary: Ollama /api/embed (local daemon, no Python deps, ~20-100 ms).
# Pull the model once: ollama pull paraphrase-multilingual:278m-mpnet-base-v2-fp16
#
# ⚠️  Model MUST produce 768-dim vectors to match existing ChromaDB collections.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=paraphrase-multilingual:278m-mpnet-base-v2-fp16

# Secondary: HuggingFace cloud Inference API (used if Ollama is unreachable).
# Free token at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here
HF_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Maximum concurrent LLM calls for agent deliberation.
# Set to 1-2 for local/slow backends (LM Studio, Ollama).
# Set to 6 for fast API backends (OpenAI, Copilot, Groq).
MAX_CONCURRENT_AGENT_CALLS=2

# =============================================================================
# LLM max_tokens per call category
# Thinking models (gemma-4-e4b, QwQ, DeepSeek-R1) use ~150-600 tokens for
# internal reasoning. Increase these when using a thinking model; reduce for
# fast non-thinking backends (GPT-4o-mini, Groq, etc.)
# All variables follow: ECHO_LLM_MAX_TOKENS_<CATEGORY>
# =============================================================================

# --- User-facing (interactive, latency-sensitive) ---
ECHO_LLM_MAX_TOKENS_AGENT=256
ECHO_LLM_MAX_TOKENS_SYNTHESIS=1024
ECHO_LLM_MAX_TOKENS_SELF_PREDICTION=300
ECHO_LLM_MAX_TOKENS_DRIVE_SCORING=400
ECHO_LLM_MAX_TOKENS_BOOTSTRAP=512

# --- Reflection & self-model ---
ECHO_LLM_MAX_TOKENS_REFLECTION=512
ECHO_LLM_MAX_TOKENS_ECHO_MD=2048
ECHO_LLM_MAX_TOKENS_METACOGNITION=300

# --- Consolidation / sleep cycles ---
ECHO_LLM_MAX_TOKENS_CONSOLIDATION_PATTERNS=512
ECHO_LLM_MAX_TOKENS_CONSOLIDATION_DEDUP=80
ECHO_LLM_MAX_TOKENS_DREAM=220
ECHO_LLM_MAX_TOKENS_CREATIVE_SYNTHESIS=130
ECHO_LLM_MAX_TOKENS_SWARM_DREAM=200

# --- Curiosity / autonomous learning ---
ECHO_LLM_MAX_TOKENS_TOPIC_EXTRACTION=400
ECHO_LLM_MAX_TOKENS_ZPD_TOPICS=400
ECHO_LLM_MAX_TOKENS_GOAL_REFLECT=1200
ECHO_LLM_MAX_TOKENS_GOAL_PURSUE=600
ECHO_LLM_MAX_TOKENS_INTEREST_INFER=100

# --- Initiative engine (proactive messages) ---
ECHO_LLM_MAX_TOKENS_INITIATIVE_INSIGHT=300
ECHO_LLM_MAX_TOKENS_INITIATIVE_QUESTION=200
ECHO_LLM_MAX_TOKENS_INITIATIVE_REFLECTION=200

# --- Learning & self-evaluation ---
ECHO_LLM_MAX_TOKENS_META_INSIGHT=150
ECHO_LLM_MAX_TOKENS_SKILL_ASSESSMENT=300

# --- Memory ---
ECHO_LLM_MAX_TOKENS_ASSOCIATIVE_CROSS=150
ECHO_LLM_MAX_TOKENS_ASSOCIATIVE_CLUSTER=300
ECHO_LLM_MAX_TOKENS_SEMANTIC_DEDUP=120
ECHO_LLM_MAX_TOKENS_SEMANTIC_CONFLICT=30
ECHO_LLM_MAX_TOKENS_SEMANTIC_MERGE=20

# --- Wiki document processing ---
ECHO_LLM_MAX_TOKENS_WIKI_INGEST=3000
ECHO_LLM_MAX_TOKENS_WIKI_PAGE=1500
ECHO_LLM_MAX_TOKENS_WIKI_UPDATE=1200
ECHO_LLM_MAX_TOKENS_WIKI_INTERACTION=1000
ECHO_LLM_MAX_TOKENS_WIKI_SEARCH=1500

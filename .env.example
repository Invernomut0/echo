# LM Studio connection
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=Qwen2.5-7B-Instruct-Q4_K_M
LM_STUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Database paths
SQLITE_PATH=data/sqlite/echo.db
CHROMA_PATH=data/chroma

# Cognitive parameters
MAX_WORKSPACE_SLOTS=7
CONSOLIDATION_INTERVAL_SECONDS=3600
REFLECTION_TRIGGER_INTERVAL=5
MEMORY_DECAY_INTERVAL_SECONDS=300

# Performance — self-prediction timeout (seconds).
# On a phone CPU (e.g. OnePlus 7 acting as LM Studio server) the self-prediction
# call can take 40-100 s. Set this to 5 or lower to keep retrieval snappy.
# Default: 10.0  (safe for most desktop CPUs)
ECHO_PREDICT_TIMEOUT_S=10.0

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=INFO

# ── Embeddings ──────────────────────────────────────────────────────────────
# Primary: local sentence-transformers (in-process, no network, ~200-800 ms on CPU).
# Requires `uv sync` after adding sentence-transformers to pyproject.toml.
#
# ⚠️  The model MUST produce vectors of the same dimension as the existing
#     ChromaDB collections (768-dim by default).
#
# Safe default (768-dim, multilingual IT/EN/ES, ~420 MB download once):
ECHO_LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
#
# Faster English-only option (384-dim) — wipe data/chroma/ before switching!
# ECHO_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Secondary: HuggingFace cloud Inference API (used if local ST fails).
# Free token at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here
HF_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
